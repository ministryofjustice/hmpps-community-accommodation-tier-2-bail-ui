{% extends "../layout.njk" %}

{% block questions %}

    <h1 class="govuk-heading-l">{{ page.title }}</h1>
    {% for questionKey, question in page.questions %}
        {{ formQuestion(questionKey,page.questions,fetchContext()) }}
    {% endfor %}

{% endblock %}

{% block button %}
    {{ govukButton({
        text: "Save and continue"
    }) }}
{% endblock %}